# ── Required ──────────────────────────────────────────────────────────────────
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_key_here

# Get your key at https://tavily.com (free tier available)
TAVILY_API_KEY=your_tavily_key_here

# ── Optional: server tuning ───────────────────────────────────────────────────
# Per-IP sliding-window rate limit (requests per minute). Set 0 to disable.
RATE_LIMIT_PER_MIN=60

# Max seconds the agent may take before the /chat endpoint returns 504.
AGENT_TIMEOUT=120

# Port for uvicorn (Railway injects $PORT automatically; ignored locally).
PORT=8000
